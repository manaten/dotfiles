{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["git"],
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": ["github.com", "api.github.com", "*.npmjs.org"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(find *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(git add *)",
      "Bash(git checkout -b *)",
      "Bash(git commit *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git stash *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(npm install)",
      "Bash(npm run build *)",
      "Bash(npm run dev *)",
      "Bash(npm run fix *)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm run typecheck *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx cdk synth *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(npx vitest *)",
      "Bash(rg *)",
      "Bash(touch *)"
    ],
    "ask": [
      "Bash(chmod +x *)",
      "Bash(curl *)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git stash *)",
      "Bash(git tag *)",
      "Bash(npm install)",
      "Bash(npm publish *)",
      "Bash(npm uninstall *)",
      "Bash(rm *)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)"
    ],
    "deny": [
      "Bash(git commit --no-verify *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git remote set-url *)",
      "Bash(mongo d *)",
      "Bash(mysql *)",
      "Bash(npm remove *)",
      "Bash(psql *)",
      "Bash(rm -rf *)",
      "Bash(gh auth *)",
      "Bash(sudo *)",
      "NotebookEdit",
      "Read(.env)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Write(.claude/settings.json)",
      "Write(.claude/settings.local.json)"
    ]
  },
  "model": "opusplan"
}
